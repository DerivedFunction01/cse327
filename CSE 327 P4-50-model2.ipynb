    "from pathlib import Path\n",
    "\n",
    "for folder in sorted(p for p in Path(\".\").iterdir() if p.is_dir() and p.name.startswith(\"size\")):\n",
    "    images = sorted(folder.glob(\"training_loss*.png\"))\n",
    "    if not images:\n",
    "        continue\n",
    "\n",
    "    img_path = images[0]\n",
    "    img = plt.imread(img_path)\n",
